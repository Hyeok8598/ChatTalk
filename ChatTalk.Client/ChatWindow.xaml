<Window x:Class="ChatTalk.Client.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChatTalk.Client"
        mc:Ignorable="d"
        Title="ChatWindow"
        Height="600" Width="400"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#1A1B26">

    <Window.Resources>
        <SolidColorBrush x:Key="MainBackgroundBrush" Color="#1A1B26"/>
        <SolidColorBrush x:Key="SubBackgroundBrush" Color="#24283B"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#2F354D"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#7C3AED"/>
        <SolidColorBrush x:Key="OtherMessageBrush" Color="#374151"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="SubTextBrush" Color="#A1A1AA"/>
        <SolidColorBrush x:Key="BorderBrushCustom" Color="#3B3F5C"/>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushCustom}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource MainBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="{StaticResource SubBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrushCustom}"
                BorderThickness="0, 0, 0, 1">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="44"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="ChatTalk"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="18"
                               FontWeight="Bold"/>
                    <TextBlock Text="Connected"
                               Foreground="{StaticResource SubTextBrush}"
                               FontSize="11"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="―"
                        FontSize="16"
                        Margin="4"
                        Click="Minimize_Click"
                        Background="Transparent"
                        Foreground="{StaticResource TextBrush}"/>

                <Button Grid.Column="2"
                        Content="□"
                        FontSize="16"
                        Margin="4"
                        Click="Maximize_Click"
                        Background="Transparent"
                        Foreground="{StaticResource TextBrush}"/>

                <Button Grid.Column="3"
                        Content="✕"
                        FontSize="14"
                        Margin="4"
                        Click="Close_Click"
                        Background="Transparent"
                        Foreground="{StaticResource TextBrush}"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Background="{StaticResource MainBackgroundBrush}">
            <StackPanel x:Name="ChatPanel" Margin="14">

                <StackPanel Margin="0,0,0,12" HorizontalAlignment="Left" MaxWidth="260">
                    <TextBlock Text="상대방"
                               Foreground="{StaticResource SubTextBrush}"
                               FontSize="11"
                               Margin="8,0,0,4"/>
                    <Border Background="{StaticResource OtherMessageBrush}"
                            CornerRadius="14"
                            Padding="12,10">
                        <TextBlock Text="안녕하세요."
                                   Foreground="{StaticResource TextBrush}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,0,0,12" HorizontalAlignment="Right" MaxWidth="260">
                    <Border Background="{StaticResource PrimaryBrush}"
                            CornerRadius="14"
                            Padding="12,10">
                        <TextBlock Text="반갑습니다."
                                   Foreground="White"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        
        <Border Grid.Row="2"
                Background="{StaticResource SubBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrushCustom}"
                BorderThickness="1,1,1,0"
                CornerRadius="18,18,0,0"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="MessageTextBox"
                         Grid.Column="0"
                         Height="42"
                         VerticalAlignment="Center"
                         Margin="0,0,10,0"/>

                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Content="전송"
                        Click="SendButton_Click"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
